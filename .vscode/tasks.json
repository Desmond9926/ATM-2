{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build server",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "build-msvc-debug",
                "--target",
                "atm_server"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": "configure msvc",
            "detail": "Build ATM server via CMake MSVC preset"
        },
        {
            "label": "build client",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "build-msvc-debug",
                "--target",
                "atm_client"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$msCompile",
            "group": "build",
            "dependsOn": "configure msvc",
            "detail": "Build ATM client via CMake MSVC preset"
        },
        {
            "label": "build all",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "build-msvc-debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "configure msvc",
            "problemMatcher": "$msCompile",
            "group": "build",
            "detail": "Build all targets via CMake MSVC preset"
        },
        {
            "label": "configure msvc",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "msvc-debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "detail": "Configure CMake with MSVC preset"
        },
        {
            "label": "clean",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "if (Test-Path 'build\\msvc') { Remove-Item -Recurse -Force 'build\\msvc' }"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "detail": "Remove MSVC CMake build outputs"
        }
    ]
}
